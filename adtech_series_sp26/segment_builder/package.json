{
  "name": "audience-segmentation-app",
  "version": "1.0.0",
  "description": "Databricks App for audience segmentation with Agent and Builder modes",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build frontend --emptyOutDir",
    "build:frontend": "vite build frontend --emptyOutDir",
    "dev": "vite frontend",
    "test": "cd frontend && vitest run",
    "test:watch": "cd frontend && vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "jsdom": "^25.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0",
    "vite": "^5.0.0"
  }
}
